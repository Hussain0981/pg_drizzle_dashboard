{
  "name": "backend_auth_ts",
  "version": "1.0.0",
  "description": "Complete authentication backend using TypeScript, Drizzle ORM, PostgreSQL with EJS support",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch src/index.ts",
    "dev:css": "npx tailwindcss -i public/css/input.css -o public/css/output.css --watch",
    "dev:client": "npx tsc --watch",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:css\" \"npm run dev:client\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "npx drizzle-kit generate:pg",
    "db:push": "drizzle-kit push:pg",
    "db:studio": "drizzle-kit studio",
    "db:drop": "drizzle-kit drop",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build:css": "npx tailwindcss -i ./src/public/css/input.css -o ./src/public/css/output.css --minify"
  },
  "keywords": [
    "node",
    "typescript",
    "drizzle",
    "postgresql",
    "auth"
  ],
  "author": "Hussain Ullah",
  "license": "ISC",
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.1",
    "ejs": "^3.1.9",
    "express": "^4.19.2",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.6",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.30",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.57.2"
  }
}