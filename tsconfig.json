{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "./public/js",
    "rootDir": "./public/ts",
    "typeRoots": [
      "./types",
      "./node_modules/@types"
    ],
  },
  "include": ["public/ts/**/*"]
}