<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify OTP</title>
    <link rel="stylesheet" href="/public/css/output.css">
</head>

<body class="bg-gray-50 h-screen flex items-center justify-center">

    <div class="w-full max-w-md p-8 bg-white shadow-2xl rounded-2xl">
        <form id="otpForm" class="space-y-6">
            <div class="text-center">
                <h1 class="text-3xl font-bold text-gray-800">Verify OTP</h1>
                <p class="text-gray-500 mt-2">Enter the 5-digit code sent to your device</p>
            </div>
            <div class="flex justify-between gap-2" id="otpContainer"></div>
            <div>
                <button id="resendOtpContainer"
                    class="w-full text-sm text-gray-600 hover:underline flex justify-end  font-semibold py-1 rounded-lg transition duration-200 ease-in-out">
                    Resend OTP
                </button>
            </div>
            <button type="submit"
                class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition duration-200 ease-in-out transform active:scale-[0.98]">
                Verify Code
            </button>
        </form>
    </div>

    <script>
        const container = document.getElementById('otpContainer');
        const resendOtp = document.querySelector('#resendOtpContainer')
        const OTP_LENGTH = 5;
        const inputs = [];

        for (let i = 0; i < OTP_LENGTH; i++) {
            const input = document.createElement('input');
            input.type = 'text';
            input.maxLength = 1;
            input.placeholder = '•';
            input.className = 'w-14 h-16 text-2xl text-center font-bold border-2 border-gray-200 rounded-xl focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all';

            container.appendChild(input);
            inputs.push(input);

            // Focus next
            input.addEventListener('input', (e) => {
                if (e.target.value && i < OTP_LENGTH - 1) {
                    inputs[i + 1].focus();
                }
            });

            // Focus back
            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && !input.value && i > 0) {
                    inputs[i - 1].focus();
                }
            });

            // Handle Paste
            input.addEventListener('paste', (e) => {
                e.preventDefault();
                if (e.clipboardData) {
                    const chars = e.clipboardData.getData('text').slice(0, OTP_LENGTH).split('');
                    chars.forEach((char, index) => {
                        if (inputs[index]) {
                            inputs[index].value = char;
                            if (index < OTP_LENGTH - 1) inputs[index + 1].focus();
                        }
                    });
                }
            });
        }

        // Submit
        document.getElementById('otpForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const otpValue = inputs.map(el => el.value).join('');

            if (otpValue.length < OTP_LENGTH) {
                alert("Please fill all OTP fields");
                return;
            }

            // console.log("OTP:", otpValue);
            try {
                const res = await fetch('/api/v1/user/verify', {
                    method: 'POST',
                    body: {
                        email: email.value,
                        otp: otpValue
                    }
                })
            } catch (error) {
                console.log(error);

            }

        });

        // resend otp
        resendOtp.addEventListener('click', async () => {
            try {
                const res = await fetch('/api/v1/user/resendOtp', {
                    method: 'POST',
                    body: {

                    }
                })
            } catch (error) {
                console.warn(error)
            }
        })
    </script>
</body>

</html>