<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Sub Menu</title>
</head>

<body>
    <div class="bg-white rounded-lg shadow p-6">
        <div>

            <!-- Page Header -->
            <div class="mb-6">
                <div class="flex items-center gap-2">
                    <span class="iconify text-emerald-500" data-icon="material-symbols:edit-square-outline"
                        data-width="22" data-height="22"></span>
                    <h2 class="text-lg font-medium text-slate-800">Edit Sub Menu</h2>
                </div>
                <p class="text-sm text-slate-400 mt-1">Manage sub menu navigation links</p>
            </div>

            <!-- Form Card -->
            <div class="bg-white border border-slate-200 rounded-xl p-6">
                <form id="form-submission">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

                        <!-- Title -->
                        <div class="flex flex-col gap-1.5">
                            <label for="title" class="text-sm font-medium text-slate-700 flex items-center gap-1.5">
                                <span class="iconify text-slate-400" data-icon="material-symbols:title" data-width="16"
                                    data-height="16"></span>
                                Title <span class="text-red-400">*</span>
                            </label>
                            <input value="<%= editId.title %>" type="text" id="title" name="title"
                                placeholder="e.g. Dashboard"
                                class="w-full border border-slate-200 bg-slate-50 text-sm text-slate-700 placeholder-slate-400 px-3 py-2.5 rounded-lg outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 focus:bg-white transition-all"
                                required />
                            <p class="text-xs text-slate-400">Display name in the sidebar</p>
                        </div>

                        <!-- Icon -->
                        <div class="flex flex-col gap-1.5">
                            <label for="icon" class="text-sm font-medium text-slate-700 flex items-center gap-1.5">
                                <span class="iconify text-slate-400" data-icon="material-symbols:star-outline"
                                    data-width="16" data-height="16"></span>
                                Icon <span class="text-red-400">*</span>
                            </label>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2" id="icon-preview">
                                    <span class="iconify text-slate-400"
                                        data-icon="<%= editId.icon || 'material-symbols:widgets-outline' %>"
                                        data-width="18" data-height="18"></span>
                                </span>
                                <input value="<%= editId.icon %>" type="text" id="icon" name="icon"
                                    placeholder="e.g. material-symbols:home"
                                    class="w-full border border-slate-200 bg-slate-50 text-sm text-slate-700 placeholder-slate-400 pl-9 pr-3 py-2.5 rounded-lg outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 focus:bg-white transition-all"
                                    required />
                            </div>
                            <p class="text-xs text-slate-400">Icon name from <a href="https://icon-sets.iconify.design"
                                    target="_blank" class="text-emerald-500 hover:underline">Iconify</a></p>
                        </div>

                        <!-- Order By -->
                        <div class="flex flex-col gap-1.5">
                            <label for="orderBy" class="text-sm font-medium text-slate-700 flex items-center gap-1.5">
                                <span class="iconify text-slate-400" data-icon="material-symbols:format-list-numbered"
                                    data-width="16" data-height="16"></span>
                                Order By <span class="text-red-400">*</span>
                            </label>
                            <input value="<%= editId.orderBy %>" type="number" id="orderBy" name="orderBy"
                                placeholder="e.g. 1, 2, 3"
                                class="w-full border border-slate-200 bg-slate-50 text-sm text-slate-700 placeholder-slate-400 px-3 py-2.5 rounded-lg outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 focus:bg-white transition-all"
                                required />
                            <p class="text-xs text-slate-400">Display order in the sidebar</p>
                        </div>

                        <!-- Parent Menu -->
                        <div class="flex flex-col gap-1.5">
                            <label for="mainMenuId"
                                class="text-sm font-medium text-slate-700 flex items-center gap-1.5">
                                <span class="iconify text-slate-400" data-icon="material-symbols:account-tree-outline"
                                    data-width="16" data-height="16"></span>
                                Parent Menu <span class="text-red-400">*</span>
                            </label>
                            <select id="mainMenuId" name="mainMenuId"
                                class="w-full border border-slate-200 bg-slate-50 text-sm text-slate-700 px-3 py-2.5 rounded-lg outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 focus:bg-white transition-all"
                                required>
                                <option value="">-- Select Parent Menu --</option>
                                <% if (mainMenu && mainMenu.data && mainMenu.data.length> 0) { %>
                                    <% mainMenu.data.forEach(function(menu) { %>
                                        <option value="<%= menu.id %>" <%=String(menu.id)===String(editId.mainMenuId)
                                            ? 'selected' : '' %>>
                                            <%= menu.title || menu.name || 'Unnamed Menu' %>
                                        </option>
                                        <% }) %>
                                            <% } else { %>
                                                <option value="" disabled>No parent menus available</option>
                                                <% } %>
                            </select>
                            <p class="text-xs text-slate-400">Select a parent menu for this item</p>
                        </div>

                        <!-- Path -->
                        <div class="flex flex-col gap-1.5 md:col-span-2">
                            <label for="path" class="text-sm font-medium text-slate-700 flex items-center gap-1.5">
                                <span class="iconify text-slate-400" data-icon="material-symbols:link" data-width="16"
                                    data-height="16"></span>
                                Path <span class="text-red-400">*</span>
                            </label>
                            <div class="relative">
                                <span
                                    class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm font-medium">/</span>
                                <input value="<%= editId.path %>" type="text" id="path" name="path"
                                    placeholder="e.g. dashboard, inventory, sales"
                                    class="w-full border border-slate-200 bg-slate-50 text-sm text-slate-700 placeholder-slate-400 pl-6 pr-3 py-2.5 rounded-lg outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 focus:bg-white transition-all"
                                    required />
                            </div>
                            <p class="text-xs text-slate-400">URL path without leading slash</p>
                        </div>

                    </div>

                    <!-- Divider -->
                    <div class="border-t border-slate-100 my-5"></div>

                    <!-- Actions -->
                    <div class="flex items-center justify-between">
                        <button type="reset"
                            class="flex items-center gap-2 px-4 py-2 text-sm text-slate-500 border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors">
                            <span class="iconify" data-icon="material-symbols:refresh" data-width="16"
                                data-height="16"></span>
                            Reset
                        </button>
                        <button type="submit" id="submit-btn"
                            class="flex items-center gap-2 px-5 py-2 bg-emerald-500 hover:bg-emerald-600 text-white text-sm font-medium rounded-lg transition-colors">
                            <span class="iconify" data-icon="material-symbols:save-outline" data-width="16"
                                data-height="16"></span>
                            Update Changes
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>

    <script>
        const subMenuId = <%= editId.id %>;

        // Icon live preview
        document.getElementById('icon').addEventListener('input', function () {
            const preview = document.querySelector('#icon-preview .iconify');
            preview.setAttribute('data-icon', this.value || 'material-symbols:widgets-outline');
        });

        document.getElementById('form-submission').addEventListener('submit', async function (e) {
            e.preventDefault();

            const btn = document.getElementById('submit-btn');
            const originalHTML = btn.innerHTML;

            btn.disabled = true;
            btn.innerHTML = `
        <span class="iconify animate-spin" data-icon="material-symbols:refresh" data-width="16" data-height="16"></span>
        Saving...
      `;

            let payload = {
                title: document.getElementById('title').value.trim(),
                icon: document.getElementById('icon').value.trim(),
                orderBy: parseInt(document.getElementById('orderBy').value),
                mainMenuId: parseInt(document.getElementById('mainMenuId').value),
                path: document.getElementById('path').value.trim(),
                id: subMenuId
            };

            try {
                const res = await fetch(`/api/v1/sub-menu/${subMenuId}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const result = await res.json();

                if (res.ok) {
                    btn.innerHTML = `<span class="iconify" data-icon="material-symbols:check-circle-outline" data-width="16" data-height="16"></span>
                    Saved! `;
                    btn.classList.replace('bg-emerald-500', 'bg-green-500');

                    setTimeout(() => {  
                        btn.disabled = false;
                        btn.classList.replace('bg-green-500', 'bg-emerald-500');
                        btn.innerHTML = originalHTML;
                    }, 2000);

                    window.history.back();

                    

                } else {
                    throw new Error(result.message || 'Update fail ho gaya');
                }

            } catch (err) {
                console.error('Error:', err.message);
                btn.innerHTML = `
                <span class="iconify" data-icon="material-symbols:error-outline" data-width="16" data-height="16"></span>
                Error!
                `;
                btn.classList.replace('bg-emerald-500', 'bg-red-500');

                setTimeout(() => {
                    btn.disabled = false;
                    btn.classList.replace('bg-red-500', 'bg-emerald-500');
                    btn.innerHTML = originalHTML;
                }, 2000);

                alert('Failed: ' + err.message);
            }
        });
    </script>
</body>

</html>