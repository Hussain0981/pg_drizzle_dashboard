<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= settings || 'Settings' %>
    </title>
    <link href="/css/output.css" rel="stylesheet">
</head>

<body>
    <!-- views/pages/settings.ejs -->
    <div class="space-y-6">

        <!-- ── Main Menu Card ── -->
        <div class="bg-white rounded-lg shadow p-6">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h2 class="text-lg font-medium text-slate-800">Main Menu Settings</h2>
                    <p class="text-sm text-slate-400 mt-1">Manage sidebar main menu navigation links</p>
                </div>
                <button id="mainMenuButton"
                    class="flex items-center gap-2 px-4 py-2 bg-emerald-500 hover:bg-emerald-600 text-white text-sm font-medium rounded-lg transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 5v14M5 12h14" />
                    </svg>
                    Add Main Menu
                </button>
            </div>

            <!-- Main Menu Table -->
            <% if (mainMenu && mainMenu.data && mainMenu.data.length> 0) { %>
                <div class="overflow-hidden border border-slate-200 rounded-lg">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-slate-50 border-b border-slate-200">
                                <th
                                    class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">
                                    #</th>
                                <th
                                    class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">
                                    Name</th>
                                <th
                                    class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">
                                    Order</th>
                                <th
                                    class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">
                                    Sub Menus</th>
                                <th
                                    class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">
                                    Status</th>
                                <th
                                    class="text-right px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">
                                    Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            <% mainMenu.data.forEach(function(menu, index) { %>
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-4 py-3 text-slate-400">
                                        <%= index + 1 %>
                                    </td>
                                    <td class="px-4 py-3">
                                        <span class="font-medium text-slate-700">
                                            <%= menu.title || menu.name || 'Unnamed' %>
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 text-slate-500">
                                        <%= menu.orderBy || '-' %>
                                    </td>
                                    <td class="px-4 py-3">
                                        <span
                                            class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600">
                                            <%= menu.subMenus ? menu.subMenus.length : 0 %> items
                                        </span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <!-- Toggle Active/Inactive -->
                                        <button
                                            onclick="toggleMainMenu('<%= menu.id %>', <%= menu.isActive ? 'true' : 'false' %>)"
                                            title="<%= menu.isActive ? 'Active' : 'Inactive' %>">
                                            <% if (menu.isActive) { %>
                                                <svg width="36" height="20" viewBox="0 0 36 20" fill="none">
                                                    <rect width="36" height="20" rx="10" fill="#10b981" />
                                                    <circle cx="26" cy="10" r="7" fill="white" />
                                                </svg>
                                                <% } else { %>
                                                    <svg width="36" height="20" viewBox="0 0 36 20" fill="none">
                                                        <rect width="36" height="20" rx="10" fill="#cbd5e1" />
                                                        <circle cx="10" cy="10" r="7" fill="white" />
                                                    </svg>
                                                    <% } %>
                                        </button>
                                    </td>
                                    <td class="px-4 py-3">
                                        <div class="flex items-center justify-end gap-2">
                                            <!-- Edit -->
                                            <button
                                                onclick="window.location.href='/settings/edit-main-menu/<%= menu.id %>'"
                                                class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200 text-slate-500 hover:text-blue-500 hover:border-blue-200 hover:bg-blue-50 transition-colors"
                                                title="Edit">
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor"
                                                    stroke-width="2" viewBox="0 0 24 24">
                                                    <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" />
                                                    <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
                                                </svg>
                                            </button>
                                            <!-- Delete -->
                                            <button
                                                onclick="deleteMainMenu('<%= menu.id %>', '<%= menu.title || menu.name %>')"
                                                class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200 text-slate-500 hover:text-red-500 hover:border-red-200 hover:bg-red-50 transition-colors"
                                                title="Delete">
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor"
                                                    stroke-width="2" viewBox="0 0 24 24">
                                                    <polyline points="3 6 5 6 21 6" />
                                                    <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6" />
                                                    <path d="M10 11v6M14 11v6" />
                                                    <path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2" />
                                                </svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                                <% }); %>
                        </tbody>
                    </table>
                </div>
                <% } else { %>
                    <div
                        class="text-center py-10 text-slate-400 text-sm border border-dashed border-slate-200 rounded-lg">
                        No main menus found. Click "Add Main Menu" to create one.
                    </div>
                    <% } %>
        </div>

        <!-- ── Sub Menu Card ── -->
        <div class="bg-white rounded-lg shadow p-6">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h2 class="text-lg font-medium text-slate-800">Sub Menu Settings</h2>
                    <p class="text-sm text-slate-400 mt-1">Manage sidebar sub menu navigation links</p>
                </div>
                <button id="subMenuButton"
                    class="flex items-center gap-2 px-4 py-2 bg-emerald-500 hover:bg-emerald-600 text-white text-sm font-medium rounded-lg transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 5v14M5 12h14" />
                    </svg>
                    Add Sub Menu
                </button>
            </div>

            <!-- Sub Menu Table — grouped by main menu -->
            <% if (mainMenu && mainMenu.data && mainMenu.data.length> 0) { %>
                <% mainMenu.data.forEach(function(menu) { %>
                    <% if (menu.subMenus && menu.subMenus.length> 0) { %>

                        <!-- Group Label -->
                        <p class="text-xs font-medium text-slate-400 uppercase tracking-wider mb-2 mt-4">
                            <%= menu.title || menu.name %>
                        </p>

                        <div class="overflow-hidden border border-slate-200 rounded-lg mb-4">
                            <table class="w-full text-sm">
                                <thead>
                                    <tr class="bg-slate-50 border-b border-slate-200">
                                        <th
                                            class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">
                                            #</th>
                                        <th
                                            class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">
                                            Name</th>
                                        <th
                                            class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">
                                            URL / Path</th>
                                        <th
                                            class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">
                                            Order</th>
                                        <th
                                            class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">
                                            Status</th>
                                        <th
                                            class="text-right px-4 py-3 text-xs font-medium text-slate-500 uppercase tracking-wider">
                                            Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100">
                                    <% menu.subMenus.forEach(function(sub, index) { %>
                                        <tr class="hover:bg-slate-50 transition-colors">
                                            <td class="px-4 py-3 text-slate-400">
                                                <%= index + 1 %>
                                            </td>
                                            <td class="px-4 py-3 font-medium text-slate-700">
                                                <%= sub.title || sub.name || 'Unnamed' %>
                                            </td>
                                            <td class="px-4 py-3">
                                                <code class="text-xs bg-slate-100 text-slate-600 px-2 py-0.5 rounded">
                                        <%= sub.url || sub.path || '-' %>
                                    </code>
                                            </td>
                                            <td class="px-4 py-3 text-slate-500">
                                                <%= sub.orderBy || '-' %>
                                            </td>
                                            <td class="px-4 py-3">
                                                <!-- Toggle -->
                                                <button
                                                    onclick="toggleSubMenu('<%= sub.id %>', <%= sub.isActive ? 'true' : 'false' %>)"
                                                    title="<%= sub.isActive ? 'Active' : 'Inactive' %>">
                                                    <% if (sub.isActive) { %>
                                                        <svg width="36" height="20" viewBox="0 0 36 20" fill="none">
                                                            <rect width="36" height="20" rx="10" fill="#10b981" />
                                                            <circle cx="26" cy="10" r="7" fill="white" />
                                                        </svg>
                                                        <% } else { %>
                                                            <svg width="36" height="20" viewBox="0 0 36 20" fill="none">
                                                                <rect width="36" height="20" rx="10" fill="#cbd5e1" />
                                                                <circle cx="10" cy="10" r="7" fill="white" />
                                                            </svg>
                                                            <% } %>
                                                </button>
                                            </td>
                                            <td class="px-4 py-3">
                                                <div class="flex items-center justify-end gap-2">
                                                    <!-- Edit -->
                                                    <button
                                                        onclick="window.location.href='/settings/edit-sub-menu/<%= sub.id %>'"
                                                        class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200 text-slate-500 hover:text-blue-500 hover:border-blue-200 hover:bg-blue-50 transition-colors"
                                                        title="Edit">
                                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor"
                                                            stroke-width="2" viewBox="0 0 24 24">
                                                            <path
                                                                d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" />
                                                            <path
                                                                d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
                                                        </svg>
                                                    </button>
                                                    <!-- Delete -->
                                                    <button
                                                        onclick="deleteSubMenu('<%= sub.id %>', '<%= sub.title || sub.name %>')"
                                                        class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200 text-slate-500 hover:text-red-500 hover:border-red-200 hover:bg-red-50 transition-colors"
                                                        title="Delete">
                                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor"
                                                            stroke-width="2" viewBox="0 0 24 24">
                                                            <polyline points="3 6 5 6 21 6" />
                                                            <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6" />
                                                            <path d="M10 11v6M14 11v6" />
                                                            <path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2" />
                                                        </svg>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }); %>
                                </tbody>
                            </table>
                        </div>

                        <% } %>
                            <% }); %>
                                <% } else { %>
                                    <div
                                        class="text-center py-10 text-slate-400 text-sm border border-dashed border-slate-200 rounded-lg">
                                        No sub menus found. Click "Add Sub Menu" to create one.
                                    </div>
                                    <% } %>
        </div>

    </div>

    <script>
        // ── Navigation ──
        document.getElementById('mainMenuButton').addEventListener('click', () => {
            window.location.href = '/settings/add-main-menu';
        });
        document.getElementById('subMenuButton').addEventListener('click', () => {
            window.location.href = '/settings/add-sub-menu';
        });

        // ── Main Menu Toggle ──
        function toggleMainMenu(id, currentStatus) {
            fetch(`/api/v1/main-menu/${id}/toggle`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ isActive: !currentStatus })
            })
                .then(res => res.json())
                .then(data => {
                    if (data.success) window.location.reload();
                    else alert('Toggle failed: ' + data.message);
                })
                .catch(() => alert('Something went wrong'));
        }

        // ── Main Menu Delete ──
        function deleteMainMenu(id, name) {
            if (!confirm(`"${name}" delete karna chahte ho? Iske sare sub menus bhi delete ho jayenge.`)) return;
            fetch(`/api/v1/main-menu/${id}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' }
            })
                .then(res => res.json())
                .then(data => {
                    if (data.success) window.location.reload();
                    else alert('Delete failed: ' + data.message);
                })
                .catch(() => alert('Something went wrong'));
        }

        // ── Sub Menu Toggle ──
        function toggleSubMenu(id, currentStatus) {
            fetch(`/api/v1/sub-menu/${id}/toggle`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ isActive: !currentStatus })
            })
                .then(res => res.json())
                .then(data => {
                    if (data.success) window.location.reload();
                    else alert('Toggle failed: ' + data.message);
                })
                .catch(() => alert('Something went wrong'));
        }

        // ── Sub Menu Delete ──
        function deleteSubMenu(id, name) {
            if (!confirm(`"${name}" delete karna chahte ho?`)) return;
            fetch(`/api/v1/sub-menu/${id}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' }
            })
                .then(res => res.json())
                .then(data => {
                    if (data.success) window.location.reload();
                    else alert('Delete failed: ' + data.message);
                })
                .catch(() => alert('Something went wrong'));
        }
    </script>
</body>

</html>