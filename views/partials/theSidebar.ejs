<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
</head>

<body>
  <!-- views/partials/theSidebar.ejs -->
<aside class="w-56 min-w-56 h-screen bg-slate-900 flex flex-col">

    <!-- Logo -->
    <div class="px-4 py-5 border-b border-slate-700/50">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-emerald-500 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M19 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2zm-7 14v-4H8v-2h4V7h2v4h4v2h-4v4h-2z" />
                </svg>
            </div>
            <div>
                <p class="text-white text-sm font-medium leading-none">PharmaOS</p>
                <p class="text-slate-500 text-xs mt-1">Management System</p>
            </div>
        </div>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 px-3 py-4 overflow-y-auto">

        <% if (mainMenu && mainMenu.data && mainMenu.data.length > 0) { %>
            <% mainMenu.data.forEach(function(menu) { %>

                <!-- Section Label -->
                <p class="text-slate-500 text-xs font-medium uppercase tracking-wider px-2 mb-2 mt-3">
                    <%= menu.title || menu.name || 'Section' %>
                </p>

                <!-- Sub Menu Items -->
                <% if (menu.subMenus && menu.subMenus.length > 0) { %>
                    <% menu.subMenus.forEach(function(sub) { %>

                        <!-- Item Row -->
                        <div class="group flex items-center gap-1 rounded-lg mb-1 px-2 py-1.5
                            <%= currentPath === (sub.url || sub.path) ? 'bg-slate-800' : 'hover:bg-slate-800/60' %>
                            transition-colors duration-150">

                            <!-- Main Link -->
                            <a href="<%= sub.url || sub.path || '#' %>"
                                class="flex items-center gap-2 flex-1 min-w-0
                                <%= currentPath === (sub.url || sub.path) ? 'text-white' : 'text-slate-400 hover:text-slate-200' %>">

                                <!-- Icon -->
                                <% if (sub.icon) { %>
                                    <img src="<%= sub.icon %>" class="w-4 h-4 flex-shrink-0" />
                                <% } else { %>
                                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <circle cx="12" cy="12" r="2"/>
                                    </svg>
                                <% } %>

                                <span class="text-sm truncate"><%= sub.title || sub.name || 'Menu Item' %></span>
                            </a>
                        </div>

                    <% }); %>
                <% } %>

                <!-- Divider -->
                <div class="border-t border-slate-700/50 my-3"></div>

            <% }); %>

        <% } else { %>
            <p class="text-slate-500 text-xs px-2">No menu items found</p>
        <% } %>

        <!-- ── Static Settings ── -->
        <a href="/settings"
            class="flex items-center gap-3 px-3 py-2 rounded-lg
            <%= currentPath === '/settings' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800/60 hover:text-slate-200' %>
            transition-colors duration-150">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="3"/>
                <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
            </svg>
            <span class="text-sm">Settings</span>
        </a>

    </nav>

    <!-- User Profile Footer -->
    <div class="px-3 py-4 border-t border-slate-700/50">
        <div class="flex items-center gap-3 px-2 py-2 rounded-lg hover:bg-slate-800/60 cursor-pointer transition-colors">
            <div class="w-8 h-8 rounded-full bg-emerald-500 flex items-center justify-center flex-shrink-0">
                <span class="text-white text-xs font-medium">
                    <%= user && user.name ? user.name.trim().split(' ').map(w => w[0]).slice(0,2).join('').toUpperCase() : 'AD' %>
                </span>
            </div>
            <div class="flex-1 min-w-0">
                <p class="text-slate-200 text-sm font-medium truncate">
                    <%= user && user.name ? user.name : 'Admin' %>
                </p>
                <p class="text-slate-500 text-xs truncate">
                    <%= user && user.role ? user.role : 'Admin' %>
                </p>
            </div>
            <a href="/logout">
                <svg class="w-4 h-4 text-slate-500 hover:text-slate-300 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9" />
                </svg>
            </a>
        </div>
    </div>

</aside>

<script>
    // ── Edit Sub Menu ──
    function editSubMenu(id, name) {
        // Option 1: redirect to edit page
        window.location.href = `/api/v1/sub-menu/${id}/edit`;

        // Option 2: modal open karna ho toh ye use karo
        // openEditModal(id, name);
    }

    // ── Delete Sub Menu ──
    function deleteSubMenu(id, name) {
        if (!confirm(`"${name}" delete karna chahte ho?`)) return;

        fetch(`/api/v1/sub-menu/${id}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                window.location.reload();
            } else {
                alert('Delete failed: ' + data.message);
            }
        })
        .catch(() => alert('Something went wrong'));
    }

    // ── Toggle Active/Inactive ──
    function toggleSubMenu(id, currentStatus) {
        fetch(`/api/v1/sub-menu/${id}/toggle`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ isActive: !currentStatus })
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                window.location.reload();
            } else {
                alert('Toggle failed: ' + data.message);
            }
        })
        .catch(() => alert('Something went wrong'));
    }
</script>
</body>

</html>